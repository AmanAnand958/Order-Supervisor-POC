# ────────────────────────────────────────────
# Order Supervisor Backend — Environment Variables
# Copy this to .env and fill in the values
# ────────────────────────────────────────────

# LLM — Groq (free tier, no credit card needed)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Database (PostgreSQL)
# For local dev via docker-compose:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_supervisor
# For Supabase (production):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-supervisor

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Log level
LOG_LEVEL=INFO
